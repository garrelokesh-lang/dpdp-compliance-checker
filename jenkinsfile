pipeline {
    agent any

    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/garrelokesh-lang/dpdp-compliance-checker.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t dpdp-app .'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh 'docker run -d -p 3001:3000 dpdp-app'
            }
        }
    }
}